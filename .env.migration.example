# =====================================================
# Environment Variables for Migrated Database + Directus
# =====================================================
# Copy this to .env.production.local and fill in the values

# =====================================================
# DATABASE CONNECTION
# =====================================================
DB_HOST=mariadb
DB_USER=user
DB_PASSWORD=Riyanitaccess@26+
DB_NAME=riyan_nextjs
DB_PORT=3306

# =====================================================
# NEXT.JS CONFIGURATION
# =====================================================
NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://riyan.com.mv

# =====================================================
# DIRECTUS CMS
# =====================================================
# Internal URL (used by Next.js server-side to call Directus)
DIRECTUS_URL=http://directus:8055

# Static API token for Next.js to access Directus
# Generate this in Directus: Settings → Access Tokens → Create Token
# Role should have read access to all content collections
DIRECTUS_TOKEN=your-directus-static-token-here

# =====================================================
# OPTIONAL: LEGACY SETTINGS
# =====================================================
# These are no longer needed with the new schema but kept for reference

# Career post types (now handled by careers table)
# CAREER_POST_TYPES=career,careers,job

# =====================================================
# DIRECTUS DOCKER ENVIRONMENT (in docker-compose.yml)
# =====================================================
# Update these in docker-compose.yml before running Directus:

# Security Keys (CRITICAL: Generate unique values for production!)
# Generate with: openssl rand -base64 32
# KEY=replace-with-random-key-min-32-chars
# SECRET=replace-with-random-secret-min-32-chars

# Admin Credentials (Change these!)
# ADMIN_EMAIL=admin@riyan.com.mv
# ADMIN_PASSWORD=ChangeThisPassword123!

# =====================================================
# NOTES
# =====================================================
# After migration:
# 1. Start Directus: docker-compose up -d directus
# 2. Login at http://localhost:8055
# 3. Create static token in Settings → Access Tokens
# 4. Copy token to DIRECTUS_TOKEN above
# 5. Configure permissions for Public role
# 6. Test API: curl http://localhost:8055/items/projects?limit=5
